# --- Application ---
APP_NAME="FYP Topic Repository"
APP_ENV=development                  # development | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Database ---
DATABASE_URL=postgresql://postgres:123@localhost:5432/fyp-db

ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:123@localhost:5432/fyp-db
# --- JWT ---
JWT_SECRET_KEY=another-secret-key-for-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


HF_API_KEY=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
USE_AI_SIMILARITY=true



# --- File Storage (S3 / MinIO) ---
STORAGE_PROVIDER=minio               # s3 | minio | local
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=fyp-documents
S3_ENDPOINT_URL=http://localhost:9000   # For MinIO; remove for real AWS S3
SIGNED_URL_EXPIRE_SECONDS=900           # 15 min

# --- File Upload Limits ---
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- Similarity Engine ---
DEFAULT_SIMILARITY_THRESHOLD=80        # percentage (0–100)
SIMILARITY_FLAG_THRESHOLD=80

# --- Password Reset ---
RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=http://localhost:8081
